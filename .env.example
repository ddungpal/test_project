# 개발 서버 URL(포트 고정·preflight 대조용). 운영(Vercel)은 무관.
APP_URL=http://localhost:3000

# ── LLM 백엔드 스위치 (callLLM 어댑터) ──
# dev=claude-p(구독 정액·공짜) / prod=api(Anthropic 종량)
LLM_BACKEND=claude-p

# fixtures 리플레이 모드: replay(녹화분만 사용·과금0) | record(없으면 호출후 녹화) | off
LLM_FIXTURES=replay

# 제목·썸네일 로컬 생성 모드(copy-local-gen): hybrid=생성·재생성은 활성 스켈레톤으로 로컬 채움($0)·'새로 써줘'는 LLM / llm=항상 LLM / local=로컬만(폴백 없음)
COPY_GEN_MODE=hybrid

# ── 비용 가드 (편당, USD) ──
COST_SOFT_CAP_USD=7
COST_HARD_CAP_USD=10
MAX_REWORK=2

# ── 리서치 scope 게이트: '기본 선택 개수' 힌트(섹션 비례). 상한 아님 — 후보는 전부 저장, 상위 N개만 기본 체크.
RESEARCH_CLAIMS_PER_SECTION=1.5     # 섹션당 기본 체크할 claim 수
RESEARCH_CONCEPTS_PER_SECTION=1     # 섹션당 기본 체크할 concept 수
RESEARCH_DEFAULT_FLOOR=2            # 기본 선택 최소 개수(섹션을 못 읽어도)
RESEARCH_DEFAULT_CEILING=8          # 기본 선택 최대 개수

# ── 검색 어댑터 (셜록 리서치·촉이 발굴) ──
# 백엔드: mock(기본·$0·결정적) | tavily(실검색, TAVILY_API_KEY 필요)
SEARCH_BACKEND=mock
# fixtures: record(없으면 호출후 녹화·stale면 TTL 초과 시 재호출) | replay(녹화분만·$0·TTL 무시) | off(항상 라이브)
SEARCH_FIXTURES=replay
TAVILY_API_KEY=
# 검색 캐시 TTL(발굴 신선도 B) — fixture(record)에서 stale 판정 기준. replay는 무시($0).
#   volatility 미지정=default. 트렌드='fast'(매일 발굴이 항상 갱신), 개념='static'.
SEARCH_CACHE_TTL_SECONDS=86400      # 1일(기본)
SEARCH_TTL_FAST_SECONDS=3600        # 1시간(트렌드·시세)
SEARCH_TTL_SLOW_SECONDS=604800      # 7일(제도·연간수치)
SEARCH_TTL_STATIC_SECONDS=2592000   # 30일(개념·정의)

# ── A/B 성과 회수 (Phase 4) ── 승자의 차순위 대비 '상대 CTR 리프트'로 결정력 판정.
AB_DECISIVE_MARGIN=0.10   # +10% 이상 → decisive
AB_MARGINAL_MARGIN=0.03   # +3% 이상 → marginal, 미만 → inconclusive
AB_VIEWS_CONF_FLOOR=0.5   # 24h 조회수 신뢰도 하한(저조회 영상 학습 약화하되 0으로 죽이진 않음)

# ── 성과 수집 자동화 (운영 자동화 ① Sub-B) ──
# 소스: manual(기본·개발은 수동 입력 → 자동 수집 cron no-op) | youtube(운영·YouTube Analytics 실수집)
PERFORMANCE_SOURCE=manual
# fixtures: record(없으면 호출후 녹화) | replay(녹화분만·$0) | off  — youtube 소스에만 적용
PERFORMANCE_FIXTURES=replay
# YouTube Analytics OAuth (PERFORMANCE_SOURCE=youtube 일 때만 필요). CTR·시청률=채널 소유자 비공개 지표 → OAuth 필수.
#   셋업: Google Cloud Console→OAuth 동의화면+클라이언트(데스크톱), scope youtube.readonly+yt-analytics.readonly,
#         1회 인증으로 refresh_token 발급 → 아래 3개 채움. (커밋 금지)
YT_OAUTH_CLIENT_ID=
YT_OAUTH_CLIENT_SECRET=
YT_OAUTH_REFRESH_TOKEN=
# 회고 자동 sweep 1회 트리거당 콘텐츠 상한(운영 LLM 비용 가드). 백로그는 다음 트리거가 멱등 처리.
RETRO_SWEEP_LIMIT=10

# ── 운영 전용 비밀 (서버 전용, 절대 NEXT_PUBLIC_ 금지·커밋 금지) ──
ANTHROPIC_API_KEY=
# 댓글 external_id 해싱용 HMAC 키 (governance §2)
COMMENT_HASH_SECRET=
# YouTube Data API v3 키 (댓글 ingest용·공개데이터·OAuth 불필요). Google Cloud Console→사용자 인증 정보
YOUTUBE_API_KEY=
# YouTube 키 풀(dev quota 헤드룸): 프로젝트/계정별 키를 쉼표로 나열. 각 10k/day → 4개=40k/day.
#   429(quota 소진) 시 다음 키로 자동 rotation. 미설정 시 위 YOUTUBE_API_KEY(단일)로 폴백.
#   ⚠️ 멀티 프로젝트 quota는 YouTube ToS 회색지대 — dev 헤드룸용(프로덕션 주력 아님). 예: k1,k2,k3,k4
YOUTUBE_API_KEYS=
# YouTube 검색 fixtures(촉이·온보더 레퍼런스): record(기본·없으면 라이브 호출후 녹화) | replay(녹화분만·$0) | off(항상 라이브)
#   dev에서 record/replay로 일일 quota $0 소모(429 실패는 캐시 안 함). YOUTUBE_API_KEY 있고 off 아닐 때만 적용.
YOUTUBE_FIXTURES=record
# 채널 제목 ingest(scripts/ingest-channel-titles.ts) 기본 채널 핸들(선택). 인자 미지정 시 폴백. 예: @zzanboo
CHANNEL_HANDLE=
# 제목 단계 외부 레퍼런스 옵트인: off(기본·미설정=off·$0·오프라인) | youtube(고조회 관련 유튜브 제목 참조, YOUTUBE_API_KEY 필요·운영 과금)
TITLE_REFERENCES=off

# owner 계정 시드(scripts/seed-owner.ts). 가입+owner 승격. 신규 생성 시에만 PASSWORD 반영.
#   ★ Phase 5 진짜 인증=이메일+비밀번호 로그인(/login). 기존 owner 비번 변경은 Supabase 대시보드
#     (Authentication→Users→비번 reset) 또는 admin updateUserById.
OWNER_EMAIL=
OWNER_PASSWORD=

# 개발용 owner 바이패스 — 로그인 없이 owner로 동작(로컬·단독·$0 개발 편의).
#   ★ Phase 5 진짜 인증(/login·미들웨어·세션) 완료됨 → 바이패스는 '선택적 개발 편의'로만 유지.
#   NODE_ENV!=='production' + 플래그=1 둘 다일 때만 동작(프로덕션 절대 작동 안 함).
#   ⚠️ 기본값 0(꺼짐). 로컬에서 로그인 없이 개발할 때만 1. 운영/스테이징 .env엔 절대 1 금지.
DEV_OWNER_BYPASS=0

# ── Supabase (Phase 1) ──
SUPABASE_URL=                          # 서버 전용(admin/service-role)
SUPABASE_SERVICE_ROLE_KEY=             # 서버 전용 비밀(RLS 우회)
NEXT_PUBLIC_SUPABASE_URL=              # 브라우저용(=SUPABASE_URL, 비밀 아님)
NEXT_PUBLIC_SUPABASE_ANON_KEY=         # 브라우저용 anon
# 마이그레이션 적용용 DB 연결 문자열(Dashboard→Settings→Database→Connection string→URI, 비밀번호 포함)
SUPABASE_DB_URL=

# --- 골든 A/B: OpenAI(GPT) 백엔드 (선택, 모델 비교 실험용) ---
# LLM_BACKEND=openai 로 전환 시 GPT 호출. 운영 기본은 api(Anthropic).
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.5
# GPT 단가(USD/1M tok). 정확값 불확실 → 보수적(높게) 기본. 비용 보고는 근사, 하드캡이 1차 안전망.
OPENAI_IN_PER_M=10
OPENAI_OUT_PER_M=30
